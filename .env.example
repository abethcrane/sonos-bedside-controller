# Copy to .env and fill in from https://developer.sonos.com
SONOS_CLIENT_ID=your_client_id
SONOS_CLIENT_SECRET=your_client_secret

# Optional — resolves Spotify "Top Tracks" favorites to artist names in the UI.
# Create an app at https://developer.spotify.com/dashboard (no user login needed).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
